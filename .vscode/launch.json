{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Gateway (attach)",
      "type": "pwa-node",
      "request": "attach",
      "port": 9230,
      "address": "localhost",
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/app",
      "sourceMaps": true,
      "smartStep": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/apps/gateway/**/*.js"
      ],
      "sourceMapPathOverrides": {
        "/app/dist/apps/gateway/main.js.map": "${workspaceFolder}/dist/apps/gateway/main.js.map",
        "webpack://bank-monorepo/./*": "${workspaceFolder}/*",
        "/app/*": "${workspaceFolder}/*"
      }
    },
    {
      "name": "Accounts (attach)",
      "type": "pwa-node",
      "request": "attach",
      "port": 9231,
      "address": "localhost",
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/app",
      "sourceMaps": true,
      "smartStep": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/apps/accounts/**/*.js"
      ],
      "sourceMapPathOverrides": {
        "/app/dist/apps/accounts/main.js.map": "${workspaceFolder}/dist/apps/accounts/main.js.map",
        "webpack://bank-monorepo/./*": "${workspaceFolder}/*",
        "/app/*": "${workspaceFolder}/*"
      }
    },
    {
      "name": "Logger (attach)",
      "type": "pwa-node",
      "request": "attach",
      "port": 9232,
      "address": "localhost",
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/app",
      "sourceMaps": true,
      "smartStep": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/apps/logger/**/*.js"
      ],
      "sourceMapPathOverrides": {
        "/app/dist/apps/logger/main.js.map": "${workspaceFolder}/dist/apps/logger/main.js.map",
        "webpack://bank-monorepo/./*": "${workspaceFolder}/*",
        "/app/*": "${workspaceFolder}/*"
      }
    }
  ]
}